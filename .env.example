# Copy this file to .env for local development.
# Do not commit real secrets in .env files.
# Prefer a staging Supabase/PostgreSQL project or a recent copy before using production data.

# Runtime mode and logs.
NODE_ENV=development
LOG_LEVEL=info

# Local API/frontend ports and CORS.
API_PORT=3001
FRONTEND_PORT=3000
CORS_ORIGIN=http://localhost:3000
API_CORS_ORIGIN=http://localhost:3000
API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Mode A: API/frontend local + cloud PostgreSQL/Supabase.
# Replace placeholders only in your untracked .env. Use the pooler URL for normal app traffic when Supabase recommends it.
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>?sslmode=require
# Optional: direct/non-pooler URL for tools that explicitly need a direct connection. This repo does not use it by default.
DIRECT_DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>?sslmode=require
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
PGSSLMODE=require

# Strapi can use a separate database. Leave blank or set to DATABASE_URL-compatible value when Strapi should use a different DB.
STRAPI_DATABASE_URL=
STRAPI_DATABASE_SSL=true

# Mode B: local Docker PostgreSQL. Uncomment these values in .env when using Docker PostgreSQL instead of cloud DB.
POSTGRES_DB=yukon_connect
POSTGRES_USER=yukon
POSTGRES_PASSWORD=change-me-in-your-local-env
# DATABASE_URL=postgresql://yukon:change-me-in-your-local-env@localhost:5432/yukon_connect
# STRAPI_DATABASE_URL=postgresql://yukon:change-me-in-your-local-env@localhost:5432/yukon_connect
# DATABASE_SSL=false
# PGSSLMODE=disable

# Strapi local secrets. Generate unique values for real local/staging/production use.
STRAPI_APP_KEYS=replace-me-key-a,replace-me-key-b
STRAPI_ADMIN_JWT_SECRET=replace-me-with-a-secure-admin-jwt-secret
STRAPI_API_TOKEN_SALT=replace-me-with-a-secure-api-token-salt
STRAPI_TRANSFER_TOKEN_SALT=replace-me-with-a-secure-transfer-token-salt
STRAPI_ENCRYPTION_KEY=replace-me-with-a-secure-32-char-key

# Optional pgAdmin profile values.
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me-in-your-local-env
