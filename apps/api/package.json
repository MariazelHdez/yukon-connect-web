{
  "name": "@yukon-connect/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node.js TypeScript API for Yukon Connect contract search.",
  "scripts": {
    "dev": "node --experimental-strip-types --watch src/server.ts",
    "start": "node --experimental-strip-types src/server.ts",
    "build": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test --experimental-strip-types 'src/**/*.test.ts'",
    "inspect:schema": "node --experimental-strip-types src/scripts/inspect-schema.ts",
    "rebuild:contract-search-index": "node --experimental-strip-types src/scripts/rebuild-contract-search-index.ts",
    "db:inspect": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/inspect-database-schema.ts",
    "generate-embeddings": "node --experimental-strip-types src/scripts/generate-embeddings.ts"
  },
  "dependencies": {
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3"
  }
}
