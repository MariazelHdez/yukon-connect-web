{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "incremental": false,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "target": "ES2020",
    "types": ["node"]
  },
  "include": ["config/**/*.ts", "src/**/*.ts", "scripts/**/*.ts", "types/**/*.d.ts"],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    ".cache",
    ".tmp",
    ".strapi",
    "src/api-disabled",
    "src/api-disabled/**"
  ]
}
