{
  "name": "yukon-connect",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for Yukon Connect, a web application for searching Yukon government contracts.",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "pnpm --recursive --parallel --if-present dev",
    "build": "pnpm --recursive --if-present build",
    "lint": "pnpm --recursive --if-present lint",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "test": "pnpm --recursive --if-present test",
    "format": "pnpm --recursive --if-present format",
    "db:inspect": "pnpm --filter @yukon-connect/api db:inspect",
    "generate-embeddings": "pnpm --filter @yukon-connect/api generate-embeddings",
    "db:check": "pnpm --filter @yukon-connect/api db:check",
    "strapi:validate": "pnpm --filter @yukon-connect/strapi strapi:validate"
  }
}
